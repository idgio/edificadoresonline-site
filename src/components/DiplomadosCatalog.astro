---
import type { DiplomadoModuleEntry } from "@/lib/diplomados";

type Props = {
  module: DiplomadoModuleEntry;
  year: number;
};

const { module, year } = Astro.props as Props;
---

<section class="mt-8 space-y-6">
  <div class="space-y-3">
    <p class="text-xs uppercase tracking-[0.18em] text-[#7f7366]">
      Diplomados {year}
    </p>
    <div class="flex flex-wrap items-center justify-between gap-4">
      <h2
        class="text-3xl font-bold text-[#1c1c1c]"
        style="font-family: 'Playfair Display', serif;"
      >
        {module.title}
      </h2>
      <p class="text-xs text-[#6a5f54]">
        {module.classes.length} clases
      </p>
    </div>
  </div>

  {
    module.imageUrl && (
      <div class="overflow-hidden rounded-[24px] border border-[#e7dccb] bg-white shadow-[0_12px_24px_rgba(17,17,17,0.06)]">
        <div class="relative h-48 md:h-56 bg-[#f1e6d5]">
          <img
            src={module.imageUrl}
            alt={`Portada ${module.title}`}
            class="h-full w-full object-cover"
          />
          <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(0,0,0,0)_38%,rgba(0,0,0,0.55)_100%)]" />
        </div>
      </div>
    )
  }

  <div class="space-y-4">
    <div class="flex items-end justify-between gap-4">
      <h3 class="text-lg font-semibold text-[#1c1c1c]">Clases</h3>
    </div>

    <div
      class="rounded-[24px] border border-[#e7dccb] bg-white shadow-[0_10px_22px_rgba(17,17,17,0.05)]"
    >
      <div class="p-5">
        <ol class="space-y-3">
          {
            module.classes.map((classItem) => (
              <li class="rounded-2xl border border-[#efe3d3] bg-[#fcfaf6] p-4">
                <div class="flex items-start justify-between gap-3">
                  <div class="min-w-0 space-y-1">
                    <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-[#7b6d61]">
                      {classItem.label}
                    </p>
                    <p class="text-sm leading-relaxed text-[#2d2d2d]">
                      {classItem.displayTitle}
                    </p>
                  </div>
                  <div class="shrink-0 flex flex-col gap-2">
                    <button
                      type="button"
                      class="rounded-full bg-[#1c1c1c] px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.12em] text-[#f7f1e7] hover:bg-[#0f0f0f] transition focus:outline-none focus-visible:ring-2 focus-visible:ring-[#1c1c1c]/40"
                      data-modal-open
                      data-video-title={classItem.title}
                      data-video-youtube={classItem.youtube_url}
                      data-video-embed={classItem.embedUrl ?? ""}
                    >
                      Ver video
                    </button>
                    {classItem.pdf_url && (
                      <button
                        type="button"
                        class="rounded-full bg-[#7b6d61] px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.12em] text-[#f7f1e7] hover:bg-[#6a5f54] transition focus:outline-none focus-visible:ring-2 focus-visible:ring-[#7b6d61]/40"
                        data-pdf-url={classItem.pdf_url}
                        data-pdf-open
                      >
                        Ver PDF
                      </button>
                    )}
                  </div>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </div>
</section>

<div
  id="diplomados-video-modal"
  class="fixed inset-0 z-50 hidden"
  aria-hidden="true"
>
  <div class="absolute inset-0 bg-black/70" data-modal-overlay></div>

  <div class="relative flex min-h-full items-center justify-center p-4">
    <div
      class="w-full max-w-4xl rounded-3xl border border-[#e7dccb] bg-[#f7f1e7] shadow-[0_24px_50px_rgba(0,0,0,0.35)]"
      role="dialog"
      aria-modal="true"
      aria-labelledby="diplomados-modal-title"
    >
      <div
        class="flex items-start justify-between gap-4 border-b border-[#e7dccb] px-5 py-4"
      >
        <div class="space-y-1">
          <p class="text-[11px] uppercase tracking-[0.18em] text-[#7f7366]">
            Diplomados
          </p>
          <h3
            id="diplomados-modal-title"
            class="text-sm font-semibold text-[#1c1c1c]"
          >
            Clase
          </h3>
        </div>
        <button
          type="button"
          class="rounded-full border border-[#d2c8b8] px-4 py-2 text-xs font-semibold text-[#3f3f3f] transition hover:border-[#111111] hover:text-[#111111]"
          data-modal-close
        >
          Cerrar
        </button>
      </div>

      <div class="p-4 md:p-5">
        <div
          class="relative w-full overflow-hidden rounded-2xl bg-black aspect-video"
        >
          <iframe
            id="diplomados-modal-iframe"
            class="h-full w-full"
            src=""
            title="Video de diplomado"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen></iframe>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById(
    "diplomados-video-modal",
  ) as HTMLElement | null;
  const iframe = document.getElementById(
    "diplomados-modal-iframe",
  ) as HTMLIFrameElement | null;
  const titleEl = document.getElementById(
    "diplomados-modal-title",
  ) as HTMLElement | null;
  const captionEl = document.getElementById(
    "diplomados-modal-caption",
  ) as HTMLElement | null;
  const overlay =
    modal?.querySelector<HTMLElement>("[data-modal-overlay]") ?? null;
  const closeButtons =
    modal?.querySelectorAll<HTMLElement>("[data-modal-close]") ?? [];
  const openButtons =
    document.querySelectorAll<HTMLElement>("[data-modal-open]");
  const pdfButtons = document.querySelectorAll<HTMLElement>("[data-pdf-open]");

  let lastFocusedElement: HTMLElement | null = null;

  const setModalOpen = (isOpen: boolean) => {
    if (!modal) return;
    modal.classList.toggle("hidden", !isOpen);
    modal.setAttribute("aria-hidden", String(!isOpen));
    document.body.classList.toggle("overflow-hidden", isOpen);

    if (!isOpen && iframe) {
      iframe.src = "";
    }
  };

  const openModal = (button: HTMLElement) => {
    const title = button.getAttribute("data-video-title") ?? "Clase";
    const embed = button.getAttribute("data-video-embed") ?? "";
    if (!embed || !iframe) return;

    lastFocusedElement = button;
    if (titleEl) titleEl.textContent = title;
    if (captionEl) captionEl.textContent = title;
    iframe.src = embed;
    setModalOpen(true);
  };

  const openPdf = (button: HTMLElement) => {
    const pdfUrl = button.getAttribute("data-pdf-url");
    if (pdfUrl) {
      window.open(pdfUrl, "_blank", "noopener,noreferrer");
    }
  };

  const closeModal = () => {
    setModalOpen(false);
    lastFocusedElement?.focus();
  };

  openButtons.forEach((button) => {
    button.addEventListener("click", () => openModal(button));
  });

  pdfButtons.forEach((button) => {
    button.addEventListener("click", () => openPdf(button));
  });

  closeButtons.forEach((button) => {
    button.addEventListener("click", closeModal);
  });

  overlay?.addEventListener("click", closeModal);

  window.addEventListener("keydown", (event) => {
    if (
      event.key === "Escape" &&
      modal &&
      !modal.classList.contains("hidden")
    ) {
      closeModal();
    }
  });
</script>
